PORT=8787
HOST=0.0.0.0

SELF_SCRAPER_API_KEY=

BROWSER_HEADLESS=true
BLOCK_RESOURCES=true
CF_MAX_WAIT_MS=28000
CF_CLICK_RETRIES=8

UPSTREAM_PROXY_SERVER=
UPSTREAM_PROXY_USERNAME=
UPSTREAM_PROXY_PASSWORD=

SCRAPER_USER_AGENT=

# WebscrapingAI fallback keys (opcjonalnie)
# Serwer wybiera klucz z największą liczbą pozostałych tokenów
# Możesz dodać dowolną ilość kluczy: WEBSCRAPINGAI_KEY_1, WEBSCRAPINGAI_KEY_2, ...
WEBSCRAPINGAI_KEY_1=
WEBSCRAPINGAI_KEY_2=
WEBSCRAPINGAI_KEY_3=
# Alternatywnie wszystkie klucze w jednej zmiennej (JSON lub przecinkami):
# WEBSCRAPINGAI_KEYS=["klucz1","klucz2"]
WEBSCRAPINGAI_KEYS=

# URL bazy webscraping.ai (domyślnie https://api.webscraping.ai)
WEBSCRAPINGAI_BASE_URL=
